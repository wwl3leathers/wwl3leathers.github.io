<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>3Leathers - Custom Leather by Walter Lewis III</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
      background-color: #fdfdfb;
      color: #333;
    }
    header {
      background-color: #4a2c2a;
      color: #fff;
      text-align: center;
      padding: 1.5rem;
    }
    nav {
      display: flex;
      justify-content: center;
      background: #333;
    }
    nav a {
      color: #fff;
      text-decoration: none;
      padding: 1rem;
      display: block;
    }
    nav a:hover {
      background: #555;
    }
    section {
      padding: 2rem;
      max-width: 900px;
      margin: auto;
    }
    h2 {
      border-bottom: 2px solid #ccc;
      padding-bottom: .5rem;
      margin-bottom: 1rem;
    }
    .gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
    }
    .gallery img {
      width: 100%;
      border-radius: 8px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.2);
    }
    .donation-qr {
      display: flex;
      gap: 2rem;
      flex-wrap: wrap;
    }
    .donation-qr div {
      flex: 1;
      min-width: 150px;
      text-align: center;
    }
    form {
      display: flex;
      flex-direction: column;
      gap: .5rem;
    }
    input, textarea, button {
      padding: .7rem;
      border: 1px solid #aaa;
      border-radius: 5px;
    }
    button {
      background: #4a2c2a;
      color: white;
      cursor: pointer;
    }
    button:hover {
      background: #6b3b39;
    }
    footer {
      background: #333;
      color: #fff;
      text-align: center;
      padding: 1rem;
      margin-top: 2rem;
    }
    .comment {
      border-bottom: 1px solid #ccc;
      margin-bottom: 1rem;
      padding-bottom: 1rem;
    }
  </style>
</head>
<body>
  <header>
    <h1>3Leathers</h1>
    <p>Custom Leather by Walter Lewis III - Bridgeport, WV</p>
    <p>Contact: +1 (304) 669-1412 | wwl3leathers@outlook.com</p>
  </header>

  <nav>
    <a href="#about">About</a>
    <a href="#gallery">Gallery</a>
    <a href="#donations">Donations</a>
    <a href="#payments">Payments</a>
    <a href="#comments">Comments</a>
  </nav>

  <section id="about">
    <h2>About</h2>
    <p>Welcome to 3Leathers! I create custom handmade leather goods with care and craftsmanship. Every item is unique, designed to last, and made right here in Bridgeport, WV.</p>
  </section>

  <section id="gallery">
    <h2>Gallery</h2>
    <div class="gallery">
      <img src="placeholder1.jpg" alt="Leatherwork example 1">
      <img src="placeholder2.jpg" alt="Leatherwork example 2">
      <img src="placeholder3.jpg" alt="Leatherwork example 3">
    </div>
  </section>

  <section id="donations">
    <h2>Donations</h2>
    <p>If you’d like to support my work, you can donate via PayPal or CashApp using the QR codes below:</p>
    <div class="donation-qr">
      <div>
        <p>PayPal</p>
        <img src="paypal-qr-placeholder.png" alt="PayPal QR Code" width="150">
      </div>
      <div>
        <p>Cash App ($unclebutch3)</p>
        <img src="cashapp-qr-placeholder.png" alt="Cash App QR Code" width="150">
      </div>
    </div>
  </section>

  <section id="payments">
    <h2>Payments</h2>
    <p>Custom orders and product payments can be arranged directly. Contact me to discuss your project!</p>
  </section>

  <section id="comments">
    <h2>Comments</h2>
    <form id="commentForm">
      <input type="text" id="name" placeholder="Your Name" required>
      <textarea id="message" placeholder="Your Comment" required></textarea>
      <button type="submit">Post Comment</button>
    </form>
    <div id="commentsList"></div>
  </section>

  <footer>
    <p>&copy; 2025 3Leathers | Handmade Custom Leatherwork</p>
  </footer>

  <script>
    const form = document.getElementById('commentForm');
    const commentsList = document.getElementById('commentsList');

    function loadComments() {
      const comments = JSON.parse(localStorage.getItem('comments')) || [];
      commentsList.innerHTML = comments.map(c => 
        `<div class="comment"><strong>${c.name}</strong><p>${c.message}</p></div>`
      ).join('');
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = document.getElementById('name').value;
      const message = document.getElementById('message').value;
      const comments = JSON.parse(localStorage.getItem('comments')) || [];
      comments.push({ name, message });
      localStorage.setItem('comments', JSON.stringify(comments));
      form.reset();
      loadComments();
    });

    loadComments();
  </script>
</body>
</html>
